# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personal_manager"

# Server
PORT=3001
NODE_ENV=development

# Encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change-me-to-a-64-char-hex-string"

# Google OAuth
# Option A: Drop the downloaded credentials JSON file here
GOOGLE_CREDENTIALS_PATH="./google-credentials.json"
#
# Option B: Or set individual variables instead
# GOOGLE_CLIENT_ID="your-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-secret"
# GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/callback"

# AI — LM Studio or OpenAI-compatible API
# LM Studio (local): leave empty, defaults to http://host.docker.internal:1234/v1
# OpenAI: set your key and base URL
AI_API_KEY=""
AI_BASE_URL="http://host.docker.internal:1234/v1"
AI_MODEL="lm-studio"
