# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personal_manager"

# Server
PORT=3001
NODE_ENV=development

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Required scopes: calendar, drive.readonly, gmail.readonly, userinfo.email
# Redirect URI must match: http://localhost:3001/api/auth/callback
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/callback"

# AI — OpenAI-compatible API (custom endpoint supported)
AI_API_KEY="sk-your-api-key"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4"
